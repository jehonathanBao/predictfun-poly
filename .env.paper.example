# Paper-live dry-run mode.
# No private keys. No signing. No real orders.

PAPER_LIVE_MARKET_DATA=true

# Use either a real Polymarket outcome token id OR a readonly orderbook URL.
# Leave empty if you want the worker to start and show token/url missing diagnostics.
PAPER_POLYMARKET_TOKEN_ID=
PAPER_MARKET_DATA_URL=

# Simulated paper wallets.
PAPER_SIMULATE_WALLETS=true
PAPER_SIM_PREDICT_WALLET_COUNT=10
PAPER_SIM_PREDICT_WALLET_FUNDS_USD=100
PAPER_SIM_POLYMARKET_HEDGE_FUNDS_USD=100

# Simulated exposure used to generate paper hedge plans.
PAPER_SIM_NET_EXPOSURE_USD=20

# Worker interval.
DRY_RUN_WORKER_INTERVAL_MS=5000

# Read-only operator event log.
OPERATOR_LOG_PATH=logs/operator-events.jsonl
