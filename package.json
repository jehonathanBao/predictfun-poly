{
  "name": "btc-predict-polymarket-hedger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "dashboard:api": "tsx src/server/hedge-dashboard.ts",
    "dashboard:frontend": "pnpm --dir frontend dev",
    "dashboard:frontend:build": "pnpm --dir frontend build",
    "cli": "tsx src/cli/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.mjs",
    "lint": "node ./node_modules/eslint/bin/eslint.js \"src/**/*.ts\" \"test/**/*.ts\" \"tests/**/*.ts\" \"vitest.config.ts\" --max-warnings=0"
  },
  "dependencies": {
    "@polymarket/clob-client": "latest",
    "@predictdotfun/sdk": "latest",
    "decimal.js": "^10.4.3",
    "ethers": "^5.8.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.18.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
